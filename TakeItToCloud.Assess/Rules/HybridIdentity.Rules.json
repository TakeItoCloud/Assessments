{
    "RulePackName": "HybridIdentity",
    "Version": "2.0.0",
    "Description": "Assessment rules for Microsoft Entra Connect hybrid identity configuration, sync health, authentication mode, and privileged account hygiene.",
    "Rules": [
        {
            "RuleId": "HYB-HLT-001",
            "CheckName": "Directory Sync Status",
            "Category": "Health",
            "DefaultSeverity": "High",
            "Enabled": true,
            "FrameworkMapping": "NIST-Identify",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Checks the age of the last Entra Connect directory synchronization against a configurable threshold (default 60 minutes)"
        },
        {
            "RuleId": "HYB-HLT-002",
            "CheckName": "Password Hash Sync Currency",
            "Category": "Health",
            "DefaultSeverity": "Medium",
            "Enabled": true,
            "FrameworkMapping": "NIST-Protect",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Checks the age of the last password hash synchronization to detect PHS pipeline issues"
        },
        {
            "RuleId": "HYB-HLT-003",
            "Category": "Health",
            "CheckName": "Directory Synchronization Errors",
            "DefaultSeverity": "Medium",
            "Enabled": true,
            "FrameworkMapping": "NIST-Identify",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Identifies user and group objects with OnPremisesProvisioningErrors indicating failed synchronization"
        },
        {
            "RuleId": "HYB-CFG-001",
            "CheckName": "Password Hash Sync Configuration",
            "Category": "Configuration",
            "DefaultSeverity": "High",
            "Enabled": true,
            "FrameworkMapping": "NIST-Protect",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Verifies that Password Hash Synchronization is enabled to provide authentication resilience and leaked credential detection, even in PTA or Federated environments"
        },
        {
            "RuleId": "HYB-CFG-002",
            "CheckName": "Authentication Mode Assessment",
            "Category": "Configuration",
            "DefaultSeverity": "Medium",
            "Enabled": true,
            "FrameworkMapping": "NIST-Protect",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Identifies the active authentication method (PHS/PTA/Federation) and flags ADFS-based federation for migration consideration"
        },
        {
            "RuleId": "HYB-CFG-003",
            "CheckName": "Entra Connect Service Account Privileges",
            "Category": "Configuration",
            "DefaultSeverity": "Critical",
            "Enabled": true,
            "FrameworkMapping": "CIS-AccessControl",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Checks that the MSOL_ Entra Connect service account is not a member of privileged AD groups such as Domain Admins or Administrators"
        },
        {
            "RuleId": "HYB-SEC-001",
            "CheckName": "On-Premises Admin Accounts Synced to Cloud",
            "Category": "Security",
            "DefaultSeverity": "High",
            "Enabled": true,
            "FrameworkMapping": "CIS-AccessControl",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "Ensure admin accounts are cloud-only",
            "Description": "Identifies on-premises Domain Admin accounts that are synchronized to Entra ID, violating the cloud/on-prem tier separation principle"
        },
        {
            "RuleId": "HYB-SEC-002",
            "CheckName": "Break-Glass Accounts Are Cloud-Only",
            "Category": "Security",
            "DefaultSeverity": "High",
            "Enabled": true,
            "FrameworkMapping": "CIS-AccessControl",
            "ZeroTrustPillar": "Identity",
            "SecureScoreMapping": "",
            "Description": "Verifies that Global Administrator break-glass accounts are cloud-only and not synchronized from on-premises AD, ensuring tenant access survives on-premises compromise"
        }
    ]
}
